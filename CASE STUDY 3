class Employee:
    """
    Encapsulates employee data and salary operations. 
    Demonstrates data hiding by keeping attributes private.
    """

    # Predefined rules for allowances and deductions (Class variables for easy extension)
    HRA_RATE = 0.20        # 20% of Basic Salary
    DA_RATE = 0.50         # 50% of Basic Salary
    PF_RATE = 0.12         # 12% of Basic Salary
    TAX_RATE_HIGH = 0.10   # 10% Tax if Gross > 50,000
    TAX_RATE_LOW = 0.05    # 5% Tax if Gross <= 50,000
    TAX_THRESHOLD = 50000  # Threshold for tax brackets

    def __init__(self, emp_id, name, designation, basic_salary, bonus=0.0):
        # Private attributes for data hiding
        self.__emp_id = emp_id
        self.__name = name
        self.__designation = designation
        self.__basic_salary = float(basic_salary)
        self.__bonus = float(bonus)

        # Variables to hold calculated components
        self.__hra = 0.0
        self.__da = 0.0
        self.__pf = 0.0
        self.__tax = 0.0
        self.__gross_salary = 0.0
        self.__net_salary = 0.0

    # Getter methods for essential encapsulated data
    def get_name(self):
        return self.__name

    def get_emp_id(self):
        return self.__emp_id

    def __calculate_salary_components(self):
        """
        Private method to automatically calculate all salary components 
        based on predefined rules. (Abstraction)
        """
        # Calculate Allowances
        self.__hra = self.__basic_salary * self.HRA_RATE
        self.__da = self.__basic_salary * self.DA_RATE

        # Compute Gross Salary
        self.__gross_salary = self.__basic_salary + self.__hra + self.__da + self.__bonus

        # Calculate Deductions
        self.__pf = self.__basic_salary * self.PF_RATE

        if self.__gross_salary > self.TAX_THRESHOLD:
            self.__tax = self.__gross_salary * self.TAX_RATE_HIGH
        else:
            self.__tax = self.__gross_salary * self.TAX_RATE_LOW

        # Compute Net Salary
        self.__net_salary = self.__gross_salary - (self.__pf + self.__tax)

    def generate_payslip(self):
        """Generates structured output for the employee."""
        # Ensure calculations are up to date before generating payslip
        self.__calculate_salary_components()

        payslip = f"""
{'='*50}
EMPLOYEE PAYSLIP
{'='*50}
Employee ID : {self.__emp_id}
Name        : {self.__name}
Designation : {self.__designation}
{'-'*50}
EARNINGS
Basic Salary: ${self.__basic_salary:,.2f}
HRA         : ${self.__hra:,.2f}
DA          : ${self.__da:,.2f}
Bonus       : ${self.__bonus:,.2f}
{'-'*50}
GROSS SALARY: ${self.__gross_salary:,.2f}
{'-'*50}
DEDUCTIONS
PF          : ${self.__pf:,.2f}
Tax         : ${self.__tax:,.2f}
{'-'*50}
NET SALARY  : ${self.__net_salary:,.2f}
{'='*50}
"""
        return payslip


class SalaryManagementSystem:
    """
    System class to handle multiple employees dynamically.
    Demonstrates scalability.
    """
    def __init__(self):
        self.employee_database = []

    def add_employee(self, emp_id, name, designation, basic_salary, bonus=0.0):
        """Creates an Employee object and stores it in the list."""
        new_employee = Employee(emp_id, name, designation, basic_salary, bonus)
        self.employee_database.append(new_employee)
        print(f"[*] Successfully added employee: {name} ({emp_id})")

    def print_all_payslips(self):
        """Iterates through all stored employees and prints their payslips."""
        if not self.employee_database:
            print("No employees currently in the system.")
            return

        print("\nGenerating Payroll Reports...\n")
        for emp in self.employee_database:
            print(emp.generate_payslip())


# --- Driver Code (Execution) ---
if __name__ == "__main__":
    # Initialize the system
    company_payroll = SalaryManagementSystem()

    # Dynamically add employees
    print("--- Initializing Employee Data ---")
    company_payroll.add_employee(input(), input(), input(), int(input()), int(input()))
